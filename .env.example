# Copier en .env et remplir. Ne jamais committer le .env réel.

# Token du bot Telegram (obtenu via @BotFather).
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...

# Identifiant du canal/groupe de destination.
# Canal public : @nom_du_canal | privé : un id numérique négatif, ex -1001234567890
TELEGRAM_CHAT_ID=@mon_canal
